# AI провайдер: auto | openai | groq
# auto — сначала пробует OpenAI, затем Groq
AI_PROVIDER=auto

# API-ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# API-ключ Groq (https://console.groq.com/keys) — бесплатный вариант
GROQ_API_KEY=

# Webhook Bitrix24 (для CRM и бронирования)
BITRIX_WEBHOOK_URL=

# Secret для передачи заявок в Atelier CRM
CRM_WEBHOOK_SECRET=

# Endpoint Atelier CRM для заявок с сайта (по умолчанию используется этот адрес)
# CRM_REQUEST_ENDPOINT=https://crm.atelie1513.ru/api/index.php?action=site_request

# Порт сервера (по умолчанию 8080)
# PORT=8080
