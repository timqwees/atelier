# AI провайдер: auto | openai | groq
# auto — сначала пробует OpenAI, затем Groq
AI_PROVIDER=auto

# API-ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# API-ключ Groq (https://console.groq.com/keys) — бесплатный вариант
GROQ_API_KEY=

# Webhook Bitrix24 (для CRM и бронирования)
BITRIX_WEBHOOK_URL=

# Порт сервера (по умолчанию 8080)
# PORT=8080
